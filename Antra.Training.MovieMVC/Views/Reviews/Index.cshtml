@model IEnumerable<ApplicationCore.Entities.Review>

<h2 class="mb-4">Reviews</h2>

<p>
    <a asp-action="Create" class="btn btn-primary mb-3">Create New Review</a>
</p>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Movie Id: @item.MovieId</h5>
                    <h6 class="card-subtitle mb-2 text-muted">User Id: @item.UserId</h6>

                    <p class="mt-2">
                        <span class="badge bg-warning text-dark">
                            ⭐ @item.Rating
                        </span>
                    </p>

                    <p class="card-text">
                        @item.ReviewText
                    </p>
                </div>

                <div class="card-footer text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </div>
            </div>
        </div>
    }
</div>