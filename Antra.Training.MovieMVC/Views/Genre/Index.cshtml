@model IEnumerable<ApplicationCore.Entities.Genre>

<h2>Genres</h2>

<a asp-action="Create" class="btn btn-success mb-3">Add Genre</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td>@g.Id</td>
                <td>@g.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@g.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@g.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
