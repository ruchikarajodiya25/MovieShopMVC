@model IEnumerable<ApplicationCore.Models.MovieCardModel>

@{
    ViewData["Title"] = "Movies";
}

<div class="container">
    <div class="row">
        @foreach (var movie in Model)
        {
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title" style="height:350px; object-fit:cover;" />
                    <div class="card-body text-center">
                        <h6 class="card-title">@movie.Title</h6>
                        <span class="badge bg-warning text-dark">⭐ @movie.Rating</span>
                        <br /><br />
                        <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="btn btn-primary btn-sm">
                            Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
